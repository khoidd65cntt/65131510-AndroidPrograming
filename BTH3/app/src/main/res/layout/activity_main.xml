<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="100dp">

    <Button
        android:id="@+id/nutso1"
        android:text="NÚT SỐ 1"
        android:textSize="37dp"
        android:textColor="#9A24AD"
        android:backgroundTint="@color/material_dynamic_primary10"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"/>

    <Button
        android:id="@+id/nutso2"
        android:textSize="37dp"
        android:text="NÚT SỐ 2"
        android:textColor="#B56833"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        />
    <Button
        android:id="@+id/nutso3"
        android:textSize="37dp"
        android:text="NÚT SỐ 3"
        android:textColor="#B56833"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        />
</LinearLayout>